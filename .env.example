# Copy this file to .env and fill in your own values
# NEVER commit the .env file itself

# Database (Neon PostgreSQL)
DATABASE_URL=jdbc:postgresql://your-host.neon.tech/budget_db?sslmode=require
DATABASE_USER=your_neon_username
DATABASE_PASSWORD=your_neon_password

# Server
SERVER_PORT=8080

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# JWT Secret (generate a random 64+ char string)
JWT_SECRET=replace-with-a-random-64-character-string-you-generate-yourself
